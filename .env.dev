# MapBox access token
# Create one at https://account.mapbox.com/access-tokens/
# Prefix with VITE_ so Vite exposes it to the client
VITE_MAPBOX_TOKEN=

# TetraFlex Logserver MySQL connection
# The DAMM TetraFlex Logserver runs MySQL 8.x on port 3306
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=tetraflexlogdb

# How often (in milliseconds) to poll the TetraFlex database for new RSSI data
# Default: 60000 (60 seconds)
SYNC_INTERVAL_MS=60000

# Maximum rows to fetch per sync batch from the TetraFlex database
# Default: 10000
SYNC_BATCH_SIZE=10000

# How many days of RSSI data to retain in the local cache
# Default: 5
RETENTION_DAYS=5
